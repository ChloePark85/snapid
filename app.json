{
  "expo": {
    "name": "SnapID",
    "slug": "snapid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snapid.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "증명사진 촬영을 위해 카메라 접근이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "사진을 선택하기 위해 갤러리 접근이 필요합니다.",
        "NSPhotoLibraryAddUsageDescription": "생성된 증명사진을 저장하기 위해 갤러리 접근이 필요합니다."
      }
    },
    "android": {
      "package": "com.snapid.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "생성된 증명사진을 갤러리에 저장합니다."
        }
      ],
      "expo-web-browser"
    ]
  }
}
